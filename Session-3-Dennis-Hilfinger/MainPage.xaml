<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Session_3_Dennis_Hilfinger.MainPage"
             Title="Manage Flights">
    <ContentPage.Resources>
        <Style x:Key="HightlightedLabelStyle" TargetType="Label">
            <Setter Property="TextColor" Value="#000000"/>
            <Style.Triggers>
                <DataTrigger
                    TargetType="Label"
                    Binding="{Binding Confirmed}"
                    Value="False">
                    <Setter Property="TextColor" Value="#FFFFFF"/>
                </DataTrigger>

            </Style.Triggers>
        </Style>
    </ContentPage.Resources>
    <ScrollView>
        <VerticalStackLayout 
            Spacing="20"
            Margin="0, 50, 0, 50">

            <Grid
                RowDefinitions="*, *"
                ColumnDefinitions="*, *, *, *"
                RowSpacing="20"
                ColumnSpacing="10">
                <HorizontalStackLayout 
                    Grid.Column="0" 
                    Grid.Row="0"
                    Spacing="10"
                    HorizontalOptions="Center">
                    <Label
                        Text="From"
                        VerticalOptions="Center" />
                    <Picker
                        x:Name="DeparturePicker"
                        VerticalOptions="Center"
                        WidthRequest="150"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
                    Grid.Column="1" 
                    Grid.Row="0"
                    Spacing="10"
                    HorizontalOptions="Center">
                    <Label
                        Text="To"
                        VerticalOptions="Center" />
                    <Picker
                        x:Name="DestinationPicker"
                        VerticalOptions="Center"
                        WidthRequest="150"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
                    Grid.Column="2" 
                    Grid.Row="0"
                    Spacing="10"
                    HorizontalOptions="Center">
                    <Label
                        Text="Cabin Type"
                        VerticalOptions="Center" />
                    <Picker
                        x:Name="CabinPicker"
                        VerticalOptions="Center"
                        WidthRequest="150"/>
                </HorizontalStackLayout>




                <HorizontalStackLayout 
                    Grid.Column="0" 
                    Grid.Row="1"
                    Spacing="10"
                    HorizontalOptions="Center">
                    <RadioButton
                        x:Name="Return"
                        GroupName="BookingType"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Content="Return"
                        IsChecked="True"/>
                    <RadioButton
                        x:Name="OneWay"
                        GroupName="BookingType"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Content="One-Way"/>
                </HorizontalStackLayout>


                <HorizontalStackLayout 
                    Grid.Column="1" 
                    Grid.Row="1"
                    Spacing="10"
                    HorizontalOptions="Center">
                    <Label
                        Text="Outbound"
                        VerticalOptions="Center" />
                    <Entry
                        x:Name="OutboundDateInput"
                        VerticalOptions="Center"
                        WidthRequest="150"
                        Placeholder="dd/mm/yyyy"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
                    Grid.Column="2" 
                    Grid.Row="1"
                    Spacing="10"
                    HorizontalOptions="Center">
                    <Label
                        Text="Return"
                        VerticalOptions="Center" />
                    <Entry
                        x:Name="ReturnDateInput"
                        VerticalOptions="Center"
                        WidthRequest="150"
                        Placeholder="dd/mm/yyyy"/>
                </HorizontalStackLayout>

                <Button 
                    Text="Apply"
                    Clicked="LoadData"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    HeightRequest="50"
                    WidthRequest="150"
                    Grid.Row="1"
                    Grid.Column="3"/>
            </Grid>

            <Grid
                ColumnDefinitions="16*, *, 8*"
                WidthRequest="1000">
                <Label
                    Text="Outbound flights:"
                    VerticalOptions="Center"
                    HorizontalOptions="Start"/>
                <CheckBox
                    x:Name="OutboundCheckBox"
                    VerticalOptions="Center"
                    HorizontalOptions="End"
                    CheckedChanged="OutboundChecked"
                    Grid.Column="1"
                    WidthRequest="20"/>
                <Label
                    Text="Display three days before and after"
                    VerticalOptions="Center"
                    HorizontalOptions="Start"
                    Grid.Column="2"/>
            </Grid>


            <CollectionView 
                x:Name="OutboundFlightGrid"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                HeightRequest="300"
                WidthRequest="1000"
                SelectionMode="Single">
                <CollectionView.Header>
                    <Grid ColumnDefinitions="*, *, *, *, 2*, *, *">
                        <Label Text="From" Grid.Column="0" FontAttributes="Bold"/>
                        <Label Text="To" Grid.Column="1" FontAttributes="Bold"/>
                        <Label Text="Date" Grid.Column="2" FontAttributes="Bold"/>
                        <Label Text="Time" Grid.Column="3" FontAttributes="Bold"/>
                        <Label Text="Flight number(s)" Grid.Column="4" FontAttributes="Bold"/>
                        <Label Text="Cabin Price" Grid.Column="5" FontAttributes="Bold"/>
                        <Label Text="Number of stops" Grid.Column="6" FontAttributes="Bold"/>
                    </Grid>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*, *, *, *, 2*, *, *">

                            <Label Text="{Binding DepartureAirport}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="0"/>
                            <Label Text="{Binding DestinationAirport}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="1"/>
                            <Label Text="{Binding FlightDate}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="2"/>
                            <Label Text="{Binding FlightTime}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="3"/>
                            <Label Text="{Binding FlightNumbers}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="4"/>
                            <Label Text="{Binding CabinPrice}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="5"/>
                            <Label Text="{Binding StopCount}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="6"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid
                ColumnDefinitions="16*, *, 8*"
                WidthRequest="1000"
                x:Name="ReturnFlightHeader">
                <Label
                    Text="Outbound flights:"
                    VerticalOptions="Center"
                    HorizontalOptions="Start"/>
                <CheckBox
                    VerticalOptions="Center"
                    x:Name="ReturnCheckBox"
                    HorizontalOptions="End"
                    CheckedChanged="ReturnChecked"
                    Grid.Column="1"
                    WidthRequest="20"/>
                <Label
                    Text="Display three days before and after"
                    VerticalOptions="Center"
                    HorizontalOptions="Start"
                    Grid.Column="2"/>
            </Grid>


            <CollectionView 
                x:Name="ReturnFlightGrid"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                HeightRequest="300"
                WidthRequest="1000"
                SelectionMode="Single">
                <CollectionView.Header>
                    <Grid ColumnDefinitions="*, *, *, *, 2*, *, *">
                        <Label Text="From" Grid.Column="0" FontAttributes="Bold"/>
                        <Label Text="To" Grid.Column="1" FontAttributes="Bold"/>
                        <Label Text="Date" Grid.Column="2" FontAttributes="Bold"/>
                        <Label Text="Time" Grid.Column="3" FontAttributes="Bold"/>
                        <Label Text="Flight number(s)" Grid.Column="4" FontAttributes="Bold"/>
                        <Label Text="Cabin Price" Grid.Column="5" FontAttributes="Bold"/>
                        <Label Text="Number of stops" Grid.Column="6" FontAttributes="Bold"/>
                    </Grid>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*, *, *, *, 2*, *, *">

                            <Label Text="{Binding DepartureAirport}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="0"/>
                            <Label Text="{Binding DestinationAirport}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="1"/>
                            <Label Text="{Binding FlightDate}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="2"/>
                            <Label Text="{Binding FlightTime}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="3"/>
                            <Label Text="{Binding FlightNumbers}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="4"/>
                            <Label Text="{Binding CabinPrice}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="5"/>
                            <Label Text="{Binding StopCount}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="6"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>


            <HorizontalStackLayout Spacing="50" HorizontalOptions="Center">
                <Label
                    Text="Confirm booking for"
                    VerticalOptions="Center"/>
                <Entry 
                    Text="1"
                    x:Name="PassengerAmount"
                    WidthRequest="50"/>
                <Label
                    Text="passenger(s)"
                    VerticalOptions="Center"/>
                <Button 
                    Text="Book Flight"
                    Clicked="BookFlight"
                    HeightRequest="50"
                    WidthRequest="150"/>
                <Button 
                    Text="Exit"
                    Clicked="Exit"
                    HeightRequest="50"
                    WidthRequest="250"
                    Margin="100, 0, 0, 0"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
