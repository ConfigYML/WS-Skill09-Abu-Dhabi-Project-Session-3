<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Session_3_Dennis_Hilfinger.BookingConfirmationPage"
             Title="BookingConfirmationPage">
    
    <ScrollView>
        <VerticalStackLayout
            Margin="0, 10, 0, 50">
            <Label 
                Text="Outbound flight details:"
                VerticalOptions="Center"
                HorizontalOptions="Start"
                Margin="0, 50, 0, 0"/>
            <Grid
        ColumnDefinitions="*, *, *, *, *"
        ColumnSpacing="10">
                <HorizontalStackLayout 
            Grid.Column="0" 
            Grid.Row="0"
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="From:"
                        FontFamily="TexBold"
                VerticalOptions="Center" />
                    <Label
                x:Name="OutboundFromLabel"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
            Grid.Column="1" 
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="To:"
                        FontFamily="TexBold"
                VerticalOptions="Center" />
                    <Label
                x:Name="OutboundToLabel"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
            Grid.Column="2" 
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Cabin Type:"
                        FontFamily="TexBold"
                VerticalOptions="Center" />
                    <Label
                x:Name="OutboundCabinTypeLabel"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>




                <HorizontalStackLayout 
            Grid.Column="3" 
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Date:"
                        FontFamily="TexBold"
                VerticalOptions="Center" />
                    <Label
                x:Name="OutboundDateLabel"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>


                <HorizontalStackLayout 
            Grid.Column="4" 
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Flight number:"
                        FontFamily="TexBold"
                VerticalOptions="Center" />
                    <Label
                x:Name="OutboundFlightNumberLabel"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

            </Grid>

            <Label 
                Text="Return flight details:"
                VerticalOptions="Center"
                HorizontalOptions="Start"
                Margin="0, 20, 0, 0"/>
            <Grid
        ColumnDefinitions="*, *, *, *, *"
        ColumnSpacing="10">
                <HorizontalStackLayout 
            Grid.Column="0" 
            Grid.Row="0"
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="From:"
                        FontFamily="TexBold"
                VerticalOptions="Center" />
                    <Label
                x:Name="ReturnFromLabel"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
            Grid.Column="1" 
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="To:"
                        FontFamily="TexBold"
                VerticalOptions="Center" />
                    <Label
                x:Name="ReturnToLabel"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
            Grid.Column="2" 
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Cabin Type:"
                        FontFamily="TexBold"
                VerticalOptions="Center" />
                    <Label
                x:Name="ReturnCabinTypeLabel"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>




                <HorizontalStackLayout 
            Grid.Column="3" 
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Date:"
                        FontFamily="TexBold"
                VerticalOptions="Center" />
                    <Label
                x:Name="ReturnDateLabel"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>


                <HorizontalStackLayout 
            Grid.Column="4" 
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Flight number:"
                        FontFamily="TexBold"
                VerticalOptions="Center" />
                    <Label
                x:Name="ReturnFlightNumberLabel"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

            </Grid>


            <Label 
                Text="Passenger details:"
                VerticalOptions="Center"
                HorizontalOptions="Start"
                Margin="0, 50, 0, 0"/>
            <Grid 
        RowDefinitions="*, *, *"
        ColumnDefinitions="*, *, *"
        ColumnSpacing="10"
        RowSpacing="10">

                <HorizontalStackLayout 
            Grid.Column="0"
            Grid.Row="0"
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Firstname:"
                VerticalOptions="Center" />
                    <Entry
                x:Name="FirstnameInput"
                WidthRequest="150"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
            Grid.Column="1"
            Grid.Row="0"
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Lastname:"
                VerticalOptions="Center" />
                    <Entry
                x:Name="LastnameInput"
                WidthRequest="150"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
            Grid.Column="2"
            Grid.Row="0"
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Birthdate:"
                VerticalOptions="Center" />
                    <Entry
                x:Name="BirthdateInput"
                WidthRequest="150"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>



                <HorizontalStackLayout 
            Grid.Column="0"
            Grid.Row="1"
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Passport number:"
                VerticalOptions="Center" />
                    <Entry
                x:Name="PassportNumberInput"
                WidthRequest="150"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
            Grid.Column="1"
            Grid.Row="1"
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Passport country:"
                VerticalOptions="Center" />
                    <Picker
                x:Name="CountryPicker"
                WidthRequest="150"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout 
            Grid.Column="2"
            Grid.Row="1"
            Spacing="10"
            HorizontalOptions="Center">
                    <Label
                Text="Phone:"
                VerticalOptions="Center" />
                    <Entry
                x:Name="PhoneInput"
                WidthRequest="150"
                VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Button
            Grid.Row="2"
            Grid.Column="2"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            WidthRequest="150"
            HeightRequest="50"
            Text="Add passenger"
            Clicked="AddPassenger"/>
            </Grid>

            <Label 
                Text="Passenger list:"
                VerticalOptions="Center"
                HorizontalOptions="Start"
                Margin="0, 50, 0, 0"/>
            <CollectionView 
        x:Name="PassengerGrid"
        VerticalOptions="Center"
        HorizontalOptions="Center"
        HeightRequest="300"
        WidthRequest="1000"
        SelectionMode="Single"
                SelectionChanged="PassengerSelectionChanged">
                <CollectionView.Header>
                    <Grid ColumnDefinitions="*, *, *, *, *, *">
                        <Label Text="Firstname" Grid.Column="0" FontAttributes="Bold"/>
                        <Label Text="Lastname" Grid.Column="1" FontAttributes="Bold"/>
                        <Label Text="Birthdate" Grid.Column="2" FontAttributes="Bold"/>
                        <Label Text="Passport number" Grid.Column="3" FontAttributes="Bold"/>
                        <Label Text="Passport Country" Grid.Column="4" FontAttributes="Bold"/>
                        <Label Text="Phone" Grid.Column="5" FontAttributes="Bold"/>
                    </Grid>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*, *, *, *, *, *">

                            <Label Text="{Binding FirstName}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="0"/>
                            <Label Text="{Binding LastName}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="1"/>
                            <Label Text="{Binding DateOfBirth}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="2"/>
                            <Label Text="{Binding PassportNumber}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="3"/>
                            <Label Text="{Binding PassportCountry.Name}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="4"/>
                            <Label Text="{Binding Phone}" Style="{StaticResource HightlightedLabelStyle}" Grid.Column="5"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button
                x:Name="RemovePassengerBtn"
        Clicked="RemovePassenger"
        Text="Remove passenger"
        IsEnabled="False"
        WidthRequest="180"
        HeightRequest="50"
        HorizontalOptions="End"
        VerticalOptions="Center"
                Margin="0, 0, 30, 0"/>

            <HorizontalStackLayout 
        Spacing="10"
        HorizontalOptions="Center">
                <Button
            HorizontalOptions="Center"
            VerticalOptions="Center"
            WidthRequest="200"
            HeightRequest="50"
            Text="Back to search for flights"
            Clicked="Cancel"/>
                <Button
            HorizontalOptions="Center"
            VerticalOptions="Center"
            WidthRequest="150"
            HeightRequest="50"
            Text="Confirm booking"
            Clicked="ConfirmBooking"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>